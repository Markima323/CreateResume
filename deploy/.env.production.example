# External Docker network shared with the ZeitPlan Nginx gateway.
PUBLIC_PROXY_NETWORK=public-proxy

# PostgreSQL. Keep this password stable after the first database initialization.
POSTGRES_DB=resume
POSTGRES_USER=resume
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

# Gemini key is used only by the backend and is never sent to the browser.
GEMINI_API_KEY=replace-with-your-google-ai-studio-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_THINKING_LEVEL=medium
