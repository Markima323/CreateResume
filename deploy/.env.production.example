# Public hostname; DNS A/AAAA records must point to the Hetzner server.
SERVER_NAME=resume.example.com
CERTBOT_EMAIL=admin@example.com

# Nginx login protecting the entire application.
BASIC_AUTH_USER=resume
BASIC_AUTH_PASSWORD=replace-with-a-long-unique-password

# PostgreSQL. Keep this password stable after the first database initialization.
POSTGRES_DB=resume
POSTGRES_USER=resume
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

# OpenAI key is used only by the backend and is never sent to the browser.
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-5.4-mini
